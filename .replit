modules = ["python-3.11", "nodejs-20"]
[agent]
expertMode = true
integrations = ["github:1.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start.sh"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "static"
publicDir = "dist"
build = ["npx", "expo", "export", "--platform", "web"]

[userenv]

[userenv.shared]
EXPO_PUBLIC_BLINK_PROJECT_ID = "mood-mosaic-app-dffxk768"
EXPO_PUBLIC_BLINK_PUBLISHABLE_KEY = "blnk_pk_-4fDJNByFGB70Bh7TT5DrdTdesSSj2Fg"
EXPO_NO_TELEMETRY = "1"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000
